{
  "expo": {
    "name": "Stack",
    "slug": "Stack",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "https://img.icons8.com/?size=100&id=85180&format=png&color=000000",
    "scheme": "stack",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/carticon.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/carticon.png",
        "backgroundColor": "#ffffff"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow this app to access your location."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
